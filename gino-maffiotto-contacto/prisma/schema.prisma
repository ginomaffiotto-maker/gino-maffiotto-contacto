generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ContactMessage {
  id            String   @id @default(cuid())
  nombre        String
  email         String
  asunto        String
  mensaje       String
  enlaces       String?
  archivoPath   String?
  archivoNombre String?
  leido         Boolean  @default(false)
  createdAt     DateTime @default(now())
}
